#!/usr/bin/env bash
# seek forward/backward in the current mpv instance

declare -a FILTER_OPTS
SEEK_SECONDS=5  # Default seek time in seconds

usage() {
    cat <<-EOF
usage: ${0##*/} [options] [SECONDS]

Seek forward or backward in the currently playing media.
If SECONDS is positive, seek forward; if negative, seek backward.
Default is 5 seconds forward if not specified.

options:
    -a, --ampv           Use the ampv socket.
    -c, --current        Only consider currently playing instances.
    -f, --fzf            Use fzf for selection instead of dmenu.
    -h, --help           Show this help message and exit.
    -l, --latest         Use the most recently used mpv instance.
    -m, --music          Use the music socket.
    -q, --quiet          Suppress error messages.
    -s, --socket SOCKET  Use the specified socket.
    -u, --umpv           Use the umpv socket.
EOF
    exit 0
}

abort() {
    if [[ "$QUIET" -ne 1 ]]; then
        echo "$1" >&2
        notify-send "mpv-seek" "$1"
    fi
    exit 1
}

get_opts() {
    while [[ "$#" -gt 0 ]]; do
        SHIFT_COUNT=1
        case "$1" in
            -a | --ampv) FILTER_OPTS+=("--ampv") ;;
            -c | --current) IS_CURRENT=1 ;;
            -f | --fzf) FZF="--fzf" ;;
            -h | --help) usage ;;
            -l | --latest) GET_LATEST=1 ;;
            -m | --music) FILTER_OPTS+=("--music") ;;
            -q | --quiet)
                QUIET=1
                QUIET_OPT="--quiet"
                ;;
            -s | --socket)
                USE_SOCKET="${2:?--socket requires a socket argument}"
                SHIFT_COUNT=2
                ;;
            -u | --umpv) FILTER_OPTS+=("--umpv") ;;
            *)
                # If not an option and is a number, treat as seek seconds
                if [[ "$1" =~ ^-?[0-9]+$ ]]; then
                    SEEK_SECONDS="$1"
                else
                    abort "Unknown option: $1"
                fi
                ;;
        esac
        shift "$SHIFT_COUNT"
    done
}

set_socket() {
    if [[ "$GET_LATEST" -eq 1 ]]; then
        # Get the most recently playing instance
        local playing
        readarray -t playing < <(mpv-currently-playing --unique --socket)
        [[ "${#playing[@]}" -eq 0 ]] && abort "No mpv instances which are currently playing media..."
        USE_SOCKET="${playing[-1]}"
    elif [[ "$IS_CURRENT" -eq 1 ]]; then
        # Get currently playing instance
        local current_opts=("--socket")
        [[ -n "$FZF" ]] && current_opts+=("$FZF")
        [[ ${#FILTER_OPTS[@]} -gt 0 ]] && current_opts+=("${FILTER_OPTS[@]}")

        USE_SOCKET="$(mpv-currently-playing "${current_opts[@]}")"
        [[ -z "$USE_SOCKET" ]] && abort "No currently playing mpv instances found."
    elif [[ ${#FILTER_OPTS[@]} -gt 0 ]]; then
        # Filter by options (ampv, music, etc.)
        local sockets
        readarray -t sockets < <(mpv-active-sockets "${FILTER_OPTS[@]}")
        [[ "${#sockets[@]}" -eq 0 ]] && abort "No matching mpv instances found."
        [[ "${#sockets[@]}" -eq 1 ]] && USE_SOCKET="${sockets[0]}" && return 0

        # If multiple sockets match, pick interactively
        local pick_opts=("${FILTER_OPTS[@]}")
        [[ -n "$FZF" ]] && pick_opts+=("$FZF")
        [[ -n "$QUIET_OPT" ]] && pick_opts+=("$QUIET_OPT")

        USE_SOCKET="$(mpv-pick "${pick_opts[@]}")"
        [[ -z "$USE_SOCKET" ]] && abort "No mpv instance selected."
    else
        # Pick interactively from all instances
        local pick_opts=()
        [[ -n "$FZF" ]] && pick_opts+=("$FZF")
        [[ -n "$QUIET_OPT" ]] && pick_opts+=("$QUIET_OPT")

        USE_SOCKET="$(mpv-pick "${pick_opts[@]}")"
        [[ -z "$USE_SOCKET" ]] && abort "No mpv instance selected."
    fi

    return 0
}

mpv_seek() {
    local socket="$1"
    local seconds="$2"

    mpv-communicate $QUIET_OPT "$socket" "$(printf '{ "command": ["seek", "%d"] }' "$seconds")"
    mpv-track "$socket"
}

main() {
    get_opts "$@"

    # If socket is not already set by options, determine it
    if [[ -z "$USE_SOCKET" ]]; then
        set_socket
    fi

    mpv_seek "$USE_SOCKET" "$SEEK_SECONDS"
}

main "$@"
